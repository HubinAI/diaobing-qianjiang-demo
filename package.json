{
  "name": "diaobing-qianjiang-demo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --config vite.config.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json",
    "test": "vitest run --config vitest.config.js",
    "test:watch": "vitest --config vitest.config.js",
    "test:e2e": "playwright test",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1 --config vite.config.ts",
    "verify": "npm run lint && npm run typecheck && npm run test && npm run test:e2e && npm run build"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "eslint": "^10.6.0",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  }
}
